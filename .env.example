# LLM Behavior Diff Configuration

# ==================== LOCAL JUDGE (Ollama) ====================
# Use local Ollama instance for semantic diff scoring (recommended for cost)
OLLAMA_HOST=http://localhost:11434
OLLAMA_JUDGE_MODEL=gemma4:e2b

# ==================== REMOTE JUDGE (OpenRouter) ====================
# Optional: Use OpenRouter for cloud-based models (requires API key)
# Uncomment to enable remote judge
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_JUDGE_MODEL=qwen/qwen3-8b

# ==================== BEHAVIOR DIFF SETTINGS ====================
# Semantic diff threshold (0-1): score above this indicates significant drift
SEMANTIC_THRESHOLD=0.15

# Timeout per prompt in seconds
TIMEOUT_PER_PROMPT=30

# Judge model temperature (0-1): lower = more deterministic
JUDGE_TEMPERATURE=0.3

# Output directory for reports
OUTPUT_DIR=./reports
